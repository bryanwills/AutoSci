@article{Gresova2022.06.08.495248,
	author = {Katarina Gresova and Vlastimil Martinek and David Cechak and Petr Simecek and Panagiotis Alexiou},
	title = {Genomic Benchmarks: A Collection of Datasets for Genomic Sequence Classification},
	elocation-id = {2022.06.08.495248},
	year = {2022},
	doi = {10.1101/2022.06.08.495248},
	publisher = {Cold Spring Harbor Laboratory},
	abstract = {In this paper, we propose a collection of curated and easily accessible sequence classification datasets in the field of genomics. The proposed collection is based on a combination of novel datasets constructed from the mining of publicly available databases and existing datasets obtained from published articles. The main aim of this effort is to create a repository for shared datasets that will make machine learning for genomics more comparable and reproducible while reducing the over-head of researchers that want to enter the field. The collection currently contains eight datasets that focus on regulatory elements (promoters, enhancers, open chromatin region) from three model organisms: human, mouse, and roundworm. A simple convolution neural network is also included in a repository and can be used as a baseline model. Benchmarks and the baseline model are distributed as the Python package {\textquoteleft}genomic-benchmarks{\textquoteright}, and the code is available at https://github.com/ML-Bioinfo-CEITEC/genomic_benchmarks.Competing Interest StatementThe authors have declared no competing interest.},
	URL = {https://www.biorxiv.org/content/early/2022/06/10/2022.06.08.495248},
	eprint = {https://www.biorxiv.org/content/early/2022/06/10/2022.06.08.495248.full.pdf},
	journal = {bioRxiv}
}


