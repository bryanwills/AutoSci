@article{zuckerman2011devicerecalls,
    author = {Zuckerman, Diana M. and Brown, Paul and Nissen, Steven E.},
    title = "{Medical Device Recalls and the FDA Approval Process}",
    journal = {Archives of Internal Medicine},
    volume = {171},
    number = {11},
    pages = {1006-1011},
    year = {2011},
    month = {06},
    abstract = "{In 1938, when the US Congress first mandated that medical products demonstrate safety and effectiveness, the law applied only to drugs, not to medical devices. Congress did not give the US Food and Drug Administration (FDA) the authority to regulate all medical devices until 1976, when it amended the Food, Drug, and Cosmetics Act in response to deaths and infertility caused by the Dalkon Shield and other contraceptive intrauterine devices. Congress and the FDA weighed 2 competing goals during passage of this legislation: providing “the public reasonable assurances of safe and effective devices”(p1339) while avoiding “overregulation”(p1339) of the industry.}",
    issn = {0003-9926},
}

